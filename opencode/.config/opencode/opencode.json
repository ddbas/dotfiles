{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "share": "disabled",
  "lsp": true,
  "mcp": {
    "chrome": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "chrome-devtools-mcp@latest",
        "--headless",
        "--no-usage-statistics"
      ]
    },
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "playwright": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"]
    }
  },
  "plugin": ["@mohak34/opencode-notifier@latest"]
}
