#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<EOF
usage: note <command> [options]

Manage notes in the notes repository.

commands:
  daily     manage daily notes
  list      list notes with optional filtering and sorting
  show      print the contents of a note by id
  zettel    manage Zettelkasten-style notes

Run 'note <command> --help' for command-specific help.
EOF
}

usage_daily() {
  cat <<EOF
usage: note daily <command> [options]

commands:
  create    create a daily note for a given date
  list      list daily notes
  show      show the daily note for a given date
  remove    remove a daily note
  update    update a daily note (append content)

Run 'note daily <command> --help' for command-specific help.
EOF
}

cmd_daily_create() {
  local_usage() {
    cat <<EOF
usage: note daily create [-h] [-f] [date]

Create a daily note for a given date.

arguments:
  date    date in YYYY-MM-DD format (default: today)

options:
  -f, --force   overwrite if the note already exists
  -h, --help    show this help message and exit

reads optional note body content from stdin.
requires NOTES_DIR environment variable to be set.
prints the created filename on success.
EOF
  }

  local force=0 date=""

  # Pre-scan for --help and --force
  local args=()
  while [[ $# -gt 0 ]]; do
    case $1 in
      -h|--help) local_usage; return 0 ;;
      -f|--force) force=1 ;;
      *) args+=("$1") ;;
    esac
    shift
  done
  set -- "${args[@]+"${args[@]}"}"

  if [[ $# -gt 1 ]]; then
    local_usage >&2
    return 1
  fi

  if [[ $# -eq 1 ]]; then
    date="$1"
  else
    date="$(date +%Y-%m-%d)"
  fi

  # Validate date format
  if [[ ! "$date" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
    echo "error: invalid date format '$date' (expected YYYY-MM-DD)" >&2
    return 1
  fi

  if [[ -z "${NOTES_DIR:-}" ]]; then
    echo "error: NOTES_DIR environment variable is not set" >&2
    return 1
  fi

  local filename="${date}.md"
  local notepath="$NOTES_DIR/notes/$filename"

  if [[ -f "$notepath" && $force -eq 0 ]]; then
    echo "error: note already exists: $filename (use -f/--force to overwrite)" >&2
    return 1
  fi

  build_header() {
    printf -- '---\ndate: %s\n---\n' "$date"
  }

  if [[ -t 0 ]]; then
    build_header > "$notepath"
  else
    { build_header; cat; } > "$notepath"
  fi

  echo "created note: $filename"
}

cmd_daily_show() {
  local_usage() {
    cat <<EOF
usage: note daily show [-h] [date]

Show the daily note for a given date.

arguments:
  date    date in YYYY-MM-DD format (default: today)

options:
  -h, --help    show this help message and exit

requires NOTES_DIR environment variable to be set.
prints the note contents to stdout.
EOF
  }

  local date=""

  # Pre-scan for --help
  local args=()
  while [[ $# -gt 0 ]]; do
    case $1 in
      -h|--help) local_usage; return 0 ;;
      *) args+=("$1") ;;
    esac
    shift
  done
  set -- "${args[@]+"${args[@]}"}"

  if [[ $# -gt 1 ]]; then
    local_usage >&2
    return 1
  fi

  if [[ $# -eq 1 ]]; then
    date="$1"
  else
    date="$(date +%Y-%m-%d)"
  fi

  # Validate date format
  if [[ ! "$date" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
    echo "error: invalid date format '$date' (expected YYYY-MM-DD)" >&2
    return 1
  fi

  if [[ -z "${NOTES_DIR:-}" ]]; then
    echo "error: NOTES_DIR environment variable is not set" >&2
    return 1
  fi

  local notepath="$NOTES_DIR/notes/${date}.md"

  if [[ ! -f "$notepath" ]]; then
    echo "error: note not found: ${date}.md" >&2
    return 1
  fi

  cat "$notepath"
}

cmd_daily_list() {
  local_usage() {
    cat <<EOF
usage: note daily list [-h] [-T tag] [--sort date|name]

List daily notes in the notes repository.

options:
  -T tag        filter by tag (searches for #tag in file content)
  --sort field  sort by: date (default, descending) or name (ascending)
  -h, --help    show this help message and exit

requires NOTES_DIR environment variable to be set.
EOF
  }

  for arg in "$@"; do
    case $arg in
      -h|--help) local_usage; return 0 ;;
    esac
  done

  cmd_list -t daily "$@"
}

cmd_daily_update() {
  local_usage() {
    cat <<EOF
usage: note daily update [-h] [--append] [date]

Update the daily note for a given date.

arguments:
  date    date in YYYY-MM-DD format (default: today)

options:
  --append      append content from stdin to the note body
  -h, --help    show this help message and exit

requires NOTES_DIR environment variable to be set.
error if the note does not exist.
EOF
  }

  local do_append=0 date=""

  # Pre-scan for --help and long options
  local args=()
  while [[ $# -gt 0 ]]; do
    case $1 in
      -h|--help) local_usage; return 0 ;;
      --append) do_append=1 ;;
      *) args+=("$1") ;;
    esac
    shift
  done
  set -- "${args[@]+"${args[@]}"}"

  if [[ $# -gt 1 ]]; then
    local_usage >&2
    return 1
  fi

  if [[ $# -eq 1 ]]; then
    date="$1"
  else
    date="$(date +%Y-%m-%d)"
  fi

  # Validate date format
  if [[ ! "$date" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
    echo "error: invalid date format '$date' (expected YYYY-MM-DD)" >&2
    return 1
  fi

  if [[ -z "${NOTES_DIR:-}" ]]; then
    echo "error: NOTES_DIR environment variable is not set" >&2
    return 1
  fi

  local notepath="$NOTES_DIR/notes/${date}.md"

  if [[ ! -f "$notepath" ]]; then
    echo "error: note not found: ${date}.md" >&2
    return 1
  fi

  # Append content from stdin
  if [[ $do_append -eq 1 ]]; then
    if [[ -t 0 ]]; then
      echo "error: --append requires content from stdin" >&2
      return 1
    fi
    cat >> "$notepath"
  fi

  echo "updated note: ${date}.md"
}

cmd_daily_remove() {
  local_usage() {
    cat <<EOF
usage: note daily remove [-f] [-h] [date]

Delete a daily note from the notes repository.

arguments:
  date          date in YYYY-MM-DD format (default: today)

options:
  -f, --force   skip confirmation (required for non-interactive use)
  -h, --help    show this help message and exit

requires NOTES_DIR environment variable to be set.
EOF
  }

  local force=0 date=""

  # Pre-scan for --help and --force
  local args=()
  while [[ $# -gt 0 ]]; do
    case $1 in
      -h|--help) local_usage; return 0 ;;
      -f|--force) force=1 ;;
      *) args+=("$1") ;;
    esac
    shift
  done
  set -- "${args[@]+"${args[@]}"}"

  if [[ $# -gt 1 ]]; then
    local_usage >&2
    return 1
  fi

  if [[ $# -eq 1 ]]; then
    date="$1"
  else
    date="$(date +%Y-%m-%d)"
  fi

  # Validate date format
  if [[ ! "$date" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
    echo "error: invalid date format '$date' (expected YYYY-MM-DD)" >&2
    return 1
  fi

  if [[ -z "${NOTES_DIR:-}" ]]; then
    echo "error: NOTES_DIR environment variable is not set" >&2
    return 1
  fi

  local notepath="$NOTES_DIR/notes/${date}.md"

  if [[ ! -f "$notepath" ]]; then
    echo "error: note not found: ${date}.md" >&2
    return 1
  fi

  if [[ $force -eq 0 ]]; then
    echo "error: use -f/--force to confirm deletion of note: ${date}.md" >&2
    return 1
  fi

  rm -f "$notepath"
  echo "removed note: ${date}.md"
}

cmd_daily() {
  if [[ $# -lt 1 ]]; then
    usage_daily >&2
    return 1
  fi

  case $1 in
    -h|--help) usage_daily; return 0 ;;
    create) shift; cmd_daily_create "$@" ;;
    list)   shift; cmd_daily_list "$@" ;;
    show)   shift; cmd_daily_show "$@" ;;
    update) shift; cmd_daily_update "$@" ;;
    remove) shift; cmd_daily_remove "$@" ;;
    *)
      echo "error: unknown command '$1'" >&2
      usage_daily >&2
      return 1
      ;;
  esac
}

usage_zettel() {
  cat <<EOF
usage: note zettel <command> [options]

commands:
  create    create a new zettel note
  list      list zettel notes
  show      show a zettel note by id
  update    update a zettel note (append content, update title/tags)
  remove    delete a zettel note

Run 'note zettel <command> --help' for command-specific help.
EOF
}

cmd_zettel_create() {
  local_usage() {
    cat <<EOF
usage: note zettel create [-h] [-t tag] [title]

Create a new zettel note in the notes repository.

arguments:
  title   optional title of the note (used as the markdown H1 and frontmatter alias)
          if omitted, the timestamp is used as the frontmatter alias and no H1 is written

options:
  -t tag        add a tag (can be repeated: -t tag1 -t tag2)
  -h, --help    show this help message and exit

reads note body content from stdin.
requires NOTES_DIR environment variable to be set.
EOF
  }

  for arg in "$@"; do
    case $arg in
      -h|--help) local_usage; return 0 ;;
    esac
  done

  tags=()
  while getopts "t:" opt; do
    case $opt in
      t) tags+=("$OPTARG") ;;
      *) local_usage >&2; return 1 ;;
    esac
  done
  shift $((OPTIND - 1))

  if [[ -z "${NOTES_DIR:-}" ]]; then
    echo "error: NOTES_DIR environment variable is not set" >&2
    return 1
  fi

  timestamp="$(date +%Y%m%d%H%M%S)"
  filename="${timestamp}.md"
  notepath="$NOTES_DIR/notes/$filename"

  # Build tag block (placed after frontmatter, before title)
  tag_block=""
  if [[ ${#tags[@]} -gt 0 ]]; then
    for tag in "${tags[@]}"; do
      tag_block+="#${tag} "
    done
    tag_block="${tag_block% }"$'\n\n'
  fi

  title=${1:-}

  build_header() {
    if [[ -n "$title" ]]; then
      printf -- '---\naliases: %s\n---\n' "$title"
    else
      printf -- '---\naliases: %s\n---\n' "$timestamp"
    fi
    if [[ -n "$tag_block" ]]; then
      printf '%s' "$tag_block"
    fi
    if [[ -n "$title" ]]; then
      printf '# %s\n\n' "$title"
    fi
  }

  if [[ -t 0 ]]; then
    build_header > "$notepath"
  else
    { build_header; cat; } > "$notepath"
  fi

  echo "created note: $filename"
}

cmd_list() {
  local_usage() {
    cat <<EOF
usage: note list [-h] [-t type] [-T tag] [--sort date|name]

List notes in the notes repository.

options:
  -t type       filter by note type: zettel or daily
  -T tag        filter by tag (searches for #tag in file content)
  --sort field  sort by: date (default, descending) or name (ascending)
  -h, --help    show this help message and exit

requires NOTES_DIR environment variable to be set.
EOF
  }

  local filter_type="" filter_tag="" sort_by="date"

  # Pre-scan for --help and --sort (getopts doesn't handle long opts)
  local args=()
  while [[ $# -gt 0 ]]; do
    case $1 in
      -h|--help) local_usage; return 0 ;;
      --sort)
        shift
        sort_by="${1:-date}"
        ;;
      --sort=*) sort_by="${1#--sort=}" ;;
      *) args+=("$1") ;;
    esac
    shift
  done
  set -- "${args[@]+"${args[@]}"}"

  while getopts "t:T:" opt; do
    case $opt in
      t) filter_type="$OPTARG" ;;
      T) filter_tag="$OPTARG" ;;
      *) local_usage >&2; return 1 ;;
    esac
  done

  if [[ -z "${NOTES_DIR:-}" ]]; then
    echo "error: NOTES_DIR environment variable is not set" >&2
    return 1
  fi

  local notes_dir="$NOTES_DIR/notes"
  if [[ ! -d "$notes_dir" ]]; then
    echo "error: notes directory not found: $notes_dir" >&2
    return 1
  fi

  # Collect matching files
  local files=()
  while IFS= read -r -d '' f; do
    local base
    base="$(basename "$f")"
    # Determine type
    local note_type=""
    if [[ "$base" =~ ^[0-9]{14}\.md$ ]]; then
      note_type="zettel"
    elif [[ "$base" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}\.md$ ]]; then
      note_type="daily"
    fi

    # Filter by type
    if [[ -n "$filter_type" && "$note_type" != "$filter_type" ]]; then
      continue
    fi

    # Filter by tag
    if [[ -n "$filter_tag" ]]; then
      if ! grep -q "#${filter_tag}" "$f" 2>/dev/null; then
        continue
      fi
    fi

    files+=("$f")
  done < <(find "$notes_dir" -maxdepth 1 -name '*.md' -print0)

  if [[ ${#files[@]} -eq 0 ]]; then
    return 0
  fi

  # Sort
  case "$sort_by" in
    name)
      printf '%s\n' "${files[@]}" | sort | while IFS= read -r f; do
        basename "$f"
      done
      ;;
    date|*)
      # Sort by modification time descending using ls -t
      printf '%s\0' "${files[@]}" | xargs -0 ls -t | while IFS= read -r f; do
        basename "$f"
      done
      ;;
  esac
}

cmd_show() {
  local_usage() {
    cat <<EOF
usage: note show [-h] <id>

Print the contents of a note by filename.

arguments:
  id    note filename, with or without .md extension (e.g. 20240511143022 or 2024-05-11.md)

options:
  -h, --help    show this help message and exit

requires NOTES_DIR environment variable to be set.
EOF
  }

  for arg in "$@"; do
    case $arg in
      -h|--help) local_usage; return 0 ;;
    esac
  done

  if [[ $# -ne 1 ]]; then
    local_usage >&2
    return 1
  fi

  if [[ -z "${NOTES_DIR:-}" ]]; then
    echo "error: NOTES_DIR environment variable is not set" >&2
    return 1
  fi

  id=$1
  # Try with .md extension, then without
  if [[ "$id" == *.md ]]; then
    notepath="$NOTES_DIR/notes/$id"
  else
    notepath="$NOTES_DIR/notes/${id}.md"
  fi

  if [[ ! -f "$notepath" ]]; then
    echo "error: note not found: $notepath" >&2
    return 1
  fi

  cat "$notepath"
}

cmd_zettel_list() {
  local_usage() {
    cat <<EOF
usage: note zettel list [-h] [-T tag] [--sort date|name]

List zettel notes in the notes repository.

options:
  -T tag        filter by tag (searches for #tag in file content)
  --sort field  sort by: date (default, descending) or name (ascending)
  -h, --help    show this help message and exit

requires NOTES_DIR environment variable to be set.
EOF
  }

  for arg in "$@"; do
    case $arg in
      -h|--help) local_usage; return 0 ;;
    esac
  done

  cmd_list -t zettel "$@"
}

cmd_zettel_show() {
  local_usage() {
    cat <<EOF
usage: note zettel show [-h] <id>

Print the contents of a zettel note by filename.

arguments:
  id    zettel note filename, with or without .md extension (e.g. 20240511143022)
        must be a zettel (timestamp-based) note, not a daily note

options:
  -h, --help    show this help message and exit

requires NOTES_DIR environment variable to be set.
EOF
  }

  for arg in "$@"; do
    case $arg in
      -h|--help) local_usage; return 0 ;;
    esac
  done

  if [[ $# -ne 1 ]]; then
    local_usage >&2
    return 1
  fi

  local id=$1
  # Strip .md extension for type check
  local base="${id%.md}"

  # Verify this is a zettel (14-digit timestamp), not a daily note
  if [[ ! "$base" =~ ^[0-9]{14}$ ]]; then
    echo "error: '$id' is not a zettel id (expected 14-digit timestamp like 20240511143022)" >&2
    return 1
  fi

  cmd_show "$id"
}

cmd_zettel_update() {
  local_usage() {
    cat <<EOF
usage: note zettel update [-h] [--append] [--title <title>] [-t tag] <id>

Update an existing zettel note.

arguments:
  id              zettel note filename, with or without .md extension (e.g. 20240511143022)
                  must be a zettel (14-digit timestamp) note, not a daily note

options:
  --append        append content from stdin to the note body
  --title title   update the frontmatter alias and H1 heading
  -t tag          add a tag (can be repeated: -t tag1 -t tag2)
  -h, --help      show this help message and exit

requires NOTES_DIR environment variable to be set.
EOF
  }

  local do_append=0 new_title="" id=""
  local tags=()

  # Pre-scan for --help and long options
  local args=()
  while [[ $# -gt 0 ]]; do
    case $1 in
      -h|--help) local_usage; return 0 ;;
      --append) do_append=1 ;;
      --title)
        shift
        new_title="${1:-}"
        ;;
      --title=*) new_title="${1#--title=}" ;;
      --tag)
        shift
        tags+=("${1:-}")
        ;;
      --tag=*) tags+=("${1#--tag=}") ;;
      *) args+=("$1") ;;
    esac
    shift
  done
  set -- "${args[@]+"${args[@]}"}"

  # getopts for short options
  while getopts "t:" opt; do
    case $opt in
      t) tags+=("$OPTARG") ;;
      *) local_usage >&2; return 1 ;;
    esac
  done
  shift $((OPTIND - 1))

  if [[ $# -ne 1 ]]; then
    local_usage >&2
    return 1
  fi

  id=$1
  local base="${id%.md}"

  # Verify zettel id format
  if [[ ! "$base" =~ ^[0-9]{14}$ ]]; then
    echo "error: '$id' is not a zettel id (expected 14-digit timestamp like 20240511143022)" >&2
    return 1
  fi

  if [[ -z "${NOTES_DIR:-}" ]]; then
    echo "error: NOTES_DIR environment variable is not set" >&2
    return 1
  fi

  local notepath="$NOTES_DIR/notes/${base}.md"
  if [[ ! -f "$notepath" ]]; then
    echo "error: note not found: $notepath" >&2
    return 1
  fi

  # Update title: replace frontmatter alias and H1 heading
  if [[ -n "$new_title" ]]; then
    # Update frontmatter aliases line
    sed -i '' "s/^aliases: .*/aliases: ${new_title}/" "$notepath"
    # Update or insert H1 heading
    if grep -q '^# ' "$notepath"; then
      sed -i '' "s/^# .*$/# ${new_title}/" "$notepath"
    else
      # Insert H1 after frontmatter closing ---
      sed -i '' "/^---$/a\\
# ${new_title}
" "$notepath"
    fi
  fi

  # Add tags: insert tag line after frontmatter if not already present
  if [[ ${#tags[@]} -gt 0 ]]; then
    for tag in "${tags[@]}"; do
      if ! grep -q "^#${tag}\b\|#${tag} \| #${tag}" "$notepath" 2>/dev/null; then
        # Find the line after the closing --- of frontmatter and add tag there
        # Strategy: append tag block before the first non-frontmatter content line
        # We'll look for the second --- line and insert tags after it
        local fm_end
        fm_end=$(awk '/^---$/{c++; if(c==2){print NR; exit}}' "$notepath")
        if [[ -n "$fm_end" ]]; then
          sed -i '' "${fm_end}a\\
#${tag}
" "$notepath"
        else
          # No frontmatter, prepend tag
          sed -i '' "1i\\
#${tag}
" "$notepath"
        fi
      fi
    done
  fi

  # Append content from stdin
  if [[ $do_append -eq 1 ]]; then
    if [[ -t 0 ]]; then
      echo "error: --append requires content from stdin" >&2
      return 1
    fi
    cat >> "$notepath"
  fi

  echo "updated note: ${base}.md"
}

cmd_zettel_remove() {
  local_usage() {
    cat <<EOF
usage: note zettel remove [-f] [-h] <id>

Delete a zettel note from the notes repository.

arguments:
  id            zettel note filename, with or without .md extension (e.g. 20240511143022)
                must be a zettel (14-digit timestamp) note, not a daily note

options:
  -f, --force   skip confirmation (required for non-interactive use)
  -h, --help    show this help message and exit

requires NOTES_DIR environment variable to be set.
EOF
  }

  local force=0

  # Pre-scan for --help and --force
  local args=()
  while [[ $# -gt 0 ]]; do
    case $1 in
      -h|--help) local_usage; return 0 ;;
      -f|--force) force=1 ;;
      *) args+=("$1") ;;
    esac
    shift
  done
  set -- "${args[@]+"${args[@]}"}"

  if [[ $# -ne 1 ]]; then
    local_usage >&2
    return 1
  fi

  local id=$1
  local base="${id%.md}"

  # Verify zettel id format
  if [[ ! "$base" =~ ^[0-9]{14}$ ]]; then
    echo "error: '$id' is not a zettel id (expected 14-digit timestamp like 20240511143022)" >&2
    return 1
  fi

  if [[ -z "${NOTES_DIR:-}" ]]; then
    echo "error: NOTES_DIR environment variable is not set" >&2
    return 1
  fi

  local notepath="$NOTES_DIR/notes/${base}.md"
  if [[ ! -f "$notepath" ]]; then
    echo "error: note not found: $notepath" >&2
    return 1
  fi

  if [[ $force -eq 0 ]]; then
    echo "error: use -f/--force to confirm deletion of note: ${base}.md" >&2
    return 1
  fi

  rm -f "$notepath"
  echo "removed note: ${base}.md"
}

cmd_zettel() {
  if [[ $# -lt 1 ]]; then
    usage_zettel >&2
    return 1
  fi

  case $1 in
    -h|--help) usage_zettel; return 0 ;;
    create) shift; cmd_zettel_create "$@" ;;
    list)   shift; cmd_zettel_list "$@" ;;
    show)   shift; cmd_zettel_show "$@" ;;
    update) shift; cmd_zettel_update "$@" ;;
    remove) shift; cmd_zettel_remove "$@" ;;
    *)
      echo "error: unknown command '$1'" >&2
      usage_zettel >&2
      return 1
      ;;
  esac
}

# Main dispatch
if [[ $# -lt 1 ]]; then
  usage >&2
  exit 1
fi

case $1 in
  -h|--help) usage; exit 0 ;;
  daily)  shift; cmd_daily "$@" ;;
  list)   shift; cmd_list "$@" ;;
  show)   shift; cmd_show "$@" ;;
  zettel) shift; cmd_zettel "$@" ;;
  *)
    echo "error: unknown command '$1'" >&2
    usage >&2
    exit 1
    ;;
esac
