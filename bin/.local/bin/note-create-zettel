#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<EOF
usage: note-create-zettel [-h] [-t tag] [title]

Create a new zettel note in the notes repository.

arguments:
  title   optional title of the note (used as the markdown H1 and frontmatter alias)
          if omitted, the timestamp is used as the frontmatter alias and no H1 is written

options:
  -t tag        add a tag (can be repeated: -t tag1 -t tag2)
  -h, --help    show this help message and exit

reads note body content from stdin.
requires NOTES_DIR environment variable to be set.
EOF
}

for arg in "$@"; do
  case $arg in
    -h|--help) usage; exit 0 ;;
  esac
done

tags=()
while getopts "t:" opt; do
  case $opt in
    t) tags+=("$OPTARG") ;;
    *) usage >&2; exit 1 ;;
  esac
done
shift $((OPTIND - 1))

if [[ -z "${NOTES_DIR:-}" ]]; then
  echo "error: NOTES_DIR environment variable is not set" >&2
  exit 1
fi

timestamp="$(date +%Y%m%d%H%M%S)"
filename="${timestamp}.md"
notepath="$NOTES_DIR/notes/$filename"

# Build tag block (placed after frontmatter, before title)
tag_block=""
if [[ ${#tags[@]} -gt 0 ]]; then
  for tag in "${tags[@]}"; do
    tag_block+="#${tag} "
  done
  tag_block="${tag_block% }"$'\n\n'
fi

title=${1:-}

build_header() {
  if [[ -n "$title" ]]; then
    printf -- '---\naliases: %s\n---\n' "$title"
  else
    printf -- '---\naliases: %s\n---\n' "$timestamp"
  fi
  if [[ -n "$tag_block" ]]; then
    printf '%s' "$tag_block"
  fi
  if [[ -n "$title" ]]; then
    printf '# %s\n\n' "$title"
  fi
}

if [[ -t 0 ]]; then
  build_header > "$notepath"
else
  { build_header; cat; } > "$notepath"
fi

echo "created note: $filename"
