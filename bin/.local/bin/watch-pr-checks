#!/usr/bin/env bash

watch -n 15 --color 'CLICOLOR_FORCE=1 gh pr checks --json name,state,bucket --template '"'"'{{range .}}{{$s := .state}}{{if eq .bucket "pass"}}{{tablerow .name (autocolor "green" $s)}}{{else if eq .bucket "fail"}}{{tablerow .name (autocolor "red" $s)}}{{else if eq .bucket "pending"}}{{tablerow .name (autocolor "yellow" $s)}}{{else if eq .bucket "skipping"}}{{tablerow .name (autocolor "cyan" $s)}}{{else if eq .bucket "cancel"}}{{tablerow .name (autocolor "magenta" $s)}}{{else}}{{tablerow .name $s}}{{end}}{{end}}{{tablerender}}'"'"
