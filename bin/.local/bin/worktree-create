#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<EOF
usage: worktree-create [-h] <branch> [base-branch]

Create a new git worktree for the given branch.

arguments:
  branch        name of the branch to create
  base-branch   branch or commit to base off (default: HEAD)

options:
  -h, --help    show this help message and exit

the worktree is created at \$REPO_DIR/worktree-<repo>-<branch>.
if .worktree.config.json exists in the current repo, files listed
under "copy" will be copied into the new worktree.
EOF
}

for arg in "$@"; do
  case $arg in
    -h|--help) usage; exit 0 ;;
  esac
done

# Validate REPO_DIR is set
if [[ -z "${REPO_DIR:-}" ]]; then
  echo "error: REPO_DIR environment variable is not set" >&2
  exit 1
fi

# Validate branch name argument
if [[ $# -lt 1 ]]; then
  echo "usage: worktree-create <branch> [base-branch]" >&2
  exit 1
fi

branch=$1
base=${2:-HEAD}

# Validate we're inside a git repo
repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || {
  echo "error: not inside a git repository" >&2
  exit 1
}

repo_name=$(basename "$repo_root")
worktree_dir="$REPO_DIR/worktree-${repo_name}-${branch}"

# Create the branch and worktree
git worktree add -b "$branch" "$worktree_dir" "$base"

echo "worktree created at: $worktree_dir"

# Copy files listed in .worktree.config.json if it exists
config_file="$repo_root/.worktree.config.json"
if [[ -f "$config_file" ]]; then
  copy_files=$(jq -r '.copy[]?' "$config_file")
  if [[ -n "$copy_files" ]]; then
    while IFS= read -r file; do
      src="$repo_root/$file"
      dest="$worktree_dir/$file"
      if [[ -f "$src" ]]; then
        mkdir -p "$(dirname "$dest")"
        cp -f "$src" "$dest"
        echo "copied: $file"
      else
        echo "warning: $file not found, skipping" >&2
      fi
    done <<< "$copy_files"
  fi
fi
