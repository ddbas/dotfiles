#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<EOF
usage: worktree <command> [options]

Manage git worktrees.

commands:
  init      initialize a .worktree.config.json file in the current repo
  add       create a new git worktree for a branch
  list      list worktree branches for the current repo
  remove    remove a git worktree by branch name

Run 'worktree <command> --help' for command-specific help.
EOF
}

# Path to the main worktree of the current repo.
# Always returns the main worktree, even when called from a linked worktree.
main_worktree_root() {
  git worktree list --porcelain | awk '/^worktree /{print substr($0,10); exit}'
}

# Compute the wrapper-managed worktree path for a given branch name.
worktree_path_for() {
  local branch=$1 main_root repo_name
  main_root=$(main_worktree_root)
  repo_name=$(basename "$main_root")
  printf '%s/worktree-%s-%s\n' "$REPO_DIR" "$repo_name" "${branch//\//-}"
}

cmd_init() {
  local_usage() {
    cat <<EOF
usage: worktree init [-h] [-f <file>]...

Initialize a .worktree.config.json file in the current git repo.

options:
  -f <file>     file to add to the copy list (can be repeated)
  -h, --help    show this help message and exit

errors if .worktree.config.json already exists.
EOF
  }

  for arg in "$@"; do
    case $arg in
      -h|--help) local_usage; return 0 ;;
    esac
  done

  # Validate we're inside a git repo
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || {
    echo "error: not inside a git repository" >&2
    return 1
  }

  config_file="$repo_root/.worktree.config.json"

  # Error if config already exists
  if [[ -f "$config_file" ]]; then
    echo "error: .worktree.config.json already exists" >&2
    return 1
  fi

  # Parse -f flags
  copy_files=()
  while getopts "f:" opt; do
    case $opt in
      f) copy_files+=("$OPTARG") ;;
      *) local_usage >&2; return 1 ;;
    esac
  done

  # Build JSON and write config
  jq -n --argjson copy "$(printf '%s\n' "${copy_files[@]+"${copy_files[@]}"}" | jq -R . | jq -s .)" \
    '{ copy: $copy }' > "$config_file"

  echo "initialized: $config_file"
}

cmd_add() {
  local_usage() {
    cat <<EOF
usage: worktree add [-h] [-b] <branch>

Create a new git worktree for the given branch.

arguments:
  branch        name of the branch to check out

options:
  -b            create the branch (must not already exist)
  -h, --help    show this help message and exit

the worktree is created at \$REPO_DIR/worktree-<repo>-<branch>.
if .worktree.config.json exists in the main repo, files listed
under "copy" will be copied into the new worktree.
EOF
  }

  for arg in "$@"; do
    case $arg in
      -h|--help) local_usage; return 0 ;;
    esac
  done

  # Validate REPO_DIR is set
  if [[ -z "${REPO_DIR:-}" ]]; then
    echo "error: REPO_DIR environment variable is not set" >&2
    return 1
  fi

  # Parse -b flag
  create_branch=false
  while getopts "b" opt; do
    case $opt in
      b) create_branch=true ;;
      *) local_usage >&2; return 1 ;;
    esac
  done
  shift $((OPTIND - 1))

  # Require exactly one positional argument: <branch>
  if [[ $# -ne 1 ]]; then
    local_usage >&2
    return 1
  fi

  branch=$1

  # Validate we're inside a git repo
  git rev-parse --show-toplevel >/dev/null 2>&1 || {
    echo "error: not inside a git repository" >&2
    return 1
  }

  main_root=$(main_worktree_root)
  worktree_dir=$(worktree_path_for "$branch")

  # Hand off to git worktree add
  if [[ "$create_branch" == true ]]; then
    git worktree add -b "$branch" "$worktree_dir"
  else
    git worktree add "$worktree_dir" "$branch"
  fi

  echo "worktree created at: $worktree_dir"

  # Copy files listed in the main repo's .worktree.config.json if present
  config_file="$main_root/.worktree.config.json"
  if [[ -f "$config_file" ]]; then
    copy_files=$(jq -r '.copy[]?' "$config_file")
    if [[ -n "$copy_files" ]]; then
      while IFS= read -r file; do
        src="$main_root/$file"
        dest="$worktree_dir/$file"
        if [[ -f "$src" ]]; then
          mkdir -p "$(dirname "$dest")"
          cp -f "$src" "$dest"
          echo "copied: $file"
        else
          echo "warning: $file not found, skipping" >&2
        fi
      done <<< "$copy_files"
    fi
  fi
}

cmd_list() {
  local_usage() {
    cat <<EOF
usage: worktree list [-h]

List branches of worktrees for the current repo.

Outputs one branch name per line, suitable for piping to other
worktree subcommands (e.g. 'worktree remove').

Only worktrees located under \$REPO_DIR/worktree-<repo>-* are listed.

options:
  -h, --help    show this help message and exit
EOF
  }

  for arg in "$@"; do
    case $arg in
      -h|--help) local_usage; return 0 ;;
      *) local_usage >&2; return 1 ;;
    esac
  done

  # Validate REPO_DIR is set
  if [[ -z "${REPO_DIR:-}" ]]; then
    echo "error: REPO_DIR environment variable is not set" >&2
    return 1
  fi

  # Validate we're inside a git repo
  git rev-parse --show-toplevel >/dev/null 2>&1 || {
    echo "error: not inside a git repository" >&2
    return 1
  }

  main_root=$(main_worktree_root)
  repo_name=$(basename "$main_root")
  prefix="$REPO_DIR/worktree-${repo_name}-"

  # Walk porcelain output, emitting branch names for matching worktrees
  current_path=
  while IFS= read -r line; do
    case $line in
      "worktree "*) current_path=${line#worktree } ;;
      "branch "*)
        if [[ "$current_path" == "$prefix"* ]]; then
          # strip refs/heads/ prefix
          echo "${line#branch refs/heads/}"
        fi
        ;;
      "")
        current_path=
        ;;
    esac
  done < <(git worktree list --porcelain)
}

cmd_remove() {
  local_usage() {
    cat <<EOF
usage: worktree remove [-f] [-h] <branch>

Remove a git worktree by branch name.

arguments:
  branch        name of the branch whose worktree to remove

options:
  -f, --force   force-remove the worktree even if it has uncommitted changes
  -h, --help    show this help message and exit

the worktree is expected at \$REPO_DIR/worktree-<repo>-<branch>.
EOF
  }

  force=false

  # Pre-process --force and --help long flags
  args=()
  for arg in "$@"; do
    case $arg in
      --force) args+=("-f") ;;
      -h|--help) local_usage; return 0 ;;
      *) args+=("$arg") ;;
    esac
  done
  set -- "${args[@]+"${args[@]}"}"

  while getopts "fh" opt; do
    case $opt in
      f) force=true ;;
      h) local_usage; return 0 ;;
      *) local_usage >&2; return 1 ;;
    esac
  done
  shift $((OPTIND - 1))

  # Validate REPO_DIR is set
  if [[ -z "${REPO_DIR:-}" ]]; then
    echo "error: REPO_DIR environment variable is not set" >&2
    return 1
  fi

  # Require exactly one positional argument: <branch>
  if [[ $# -ne 1 ]]; then
    local_usage >&2
    return 1
  fi

  branch=$1

  # Validate we're inside a git repo
  git rev-parse --show-toplevel >/dev/null 2>&1 || {
    echo "error: not inside a git repository" >&2
    return 1
  }

  worktree_dir=$(worktree_path_for "$branch")

  if [[ "$force" == true ]]; then
    git worktree remove --force "$worktree_dir"
  else
    git worktree remove "$worktree_dir"
  fi

  echo "worktree removed: $worktree_dir"
}

# Main dispatch
if [[ $# -lt 1 ]]; then
  usage >&2
  exit 1
fi

case $1 in
  -h|--help) usage; exit 0 ;;
  init)   shift; cmd_init "$@" ;;
  add)    shift; cmd_add "$@" ;;
  list)   shift; cmd_list "$@" ;;
  remove) shift; cmd_remove "$@" ;;
  *)
    echo "error: unknown command '$1'" >&2
    usage >&2
    exit 1
    ;;
esac
