#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<EOF
usage: worktree <command> [options]

Manage git worktrees.

commands:
  add       create a new git worktree for a branch
  list      list worktree branches for the current repo
  remove    remove a git worktree by branch name
  config    get or set repo-level worktree configuration

Run 'worktree <command> --help' for command-specific help.
EOF
}

# Path to the main worktree of the current repo.
# Always returns the main worktree, even when called from a linked worktree.
main_worktree_root() {
  git worktree list --porcelain | awk '/^worktree /{print substr($0,10); exit}'
}

# Compute the wrapper-managed worktree path for a given branch name.
worktree_path_for() {
  local branch=$1 main_root repo_name
  main_root=$(main_worktree_root)
  repo_name=$(basename "$main_root")
  printf '%s/worktree-%s-%s\n' "$REPO_DIR" "$repo_name" "${branch//\//-}"
}

cmd_config() {
  local_usage() {
    cat <<EOF
usage: worktree config [-h] [--unset] [--list] <key> [<value>]

Get or set repo-level worktree configuration via git config.

Configuration is stored under the 'personal.worktree' namespace in the
local git config (.git/config) and is visible from all worktrees of the
same repo.

arguments:
  key           config key (e.g. personal.worktree.copy)
  value         value to set or unset

options:
  --list        list all personal.worktree.* config keys
  --unset       remove a specific value for the given key
  -h, --help    show this help message and exit

examples:
  worktree config --list
  worktree config --add personal.worktree.copy .env
  worktree config --unset personal.worktree.copy .env
EOF
  }

  for arg in "$@"; do
    case $arg in
      -h|--help) local_usage; return 0 ;;
    esac
  done

  # Validate we're inside a git repo
  git rev-parse --show-toplevel >/dev/null 2>&1 || {
    echo "error: not inside a git repository" >&2
    return 1
  }

  if [[ $# -eq 0 ]]; then
    local_usage >&2
    return 1
  fi

  case $1 in
    --list)
      git config --local --get-regexp '^personal\.worktree\.' 2>/dev/null || true
      ;;
    --add)
      if [[ $# -ne 3 ]]; then local_usage >&2; return 1; fi
      git config --local --add "$2" "$3"
      ;;
    --unset)
      if [[ $# -ne 3 ]]; then local_usage >&2; return 1; fi
      git config --local --unset "$2" "^${3}$"
      ;;
    *)
      local_usage >&2
      return 1
      ;;
  esac
}

cmd_add() {
  local_usage() {
    cat <<EOF
usage: worktree add [-h] [-b] <branch> [<ref>]

Create a new git worktree for the given branch.

arguments:
  branch        name of the branch to check out (or create with -b)
  ref           commit-ish to create the branch from (required with -b)

options:
  -b            create the branch (must not already exist); requires <ref>
  -h, --help    show this help message and exit

the worktree is created at \$REPO_DIR/worktree-<repo>-<branch>.
files listed under personal.worktree.copy in git config will be
copied into the new worktree if present in the main worktree.
EOF
  }

  for arg in "$@"; do
    case $arg in
      -h|--help) local_usage; return 0 ;;
    esac
  done

  # Validate REPO_DIR is set
  if [[ -z "${REPO_DIR:-}" ]]; then
    echo "error: REPO_DIR environment variable is not set" >&2
    return 1
  fi

  # Parse -b flag
  create_branch=false
  while getopts "b" opt; do
    case $opt in
      b) create_branch=true ;;
      *) local_usage >&2; return 1 ;;
    esac
  done
  shift $((OPTIND - 1))

  # Require correct number of positional arguments
  if [[ "$create_branch" == true ]]; then
    if [[ $# -ne 2 ]]; then
      local_usage >&2
      return 1
    fi
    branch=$1
    ref=$2
  else
    if [[ $# -ne 1 ]]; then
      local_usage >&2
      return 1
    fi
    branch=$1
    ref=
  fi

  # Validate we're inside a git repo
  git rev-parse --show-toplevel >/dev/null 2>&1 || {
    echo "error: not inside a git repository" >&2
    return 1
  }

  main_root=$(main_worktree_root)
  worktree_dir=$(worktree_path_for "$branch")

  # Hand off to git worktree add
  if [[ "$create_branch" == true ]]; then
    git worktree add -b "$branch" "$worktree_dir" "$ref"
  else
    git worktree add "$worktree_dir" "$branch"
  fi

  echo "worktree created at: $worktree_dir"

  # Copy files listed in personal.worktree.copy git config if any
  copy_files=$(git config --local --get-all personal.worktree.copy 2>/dev/null || true)
  if [[ -n "$copy_files" ]]; then
    while IFS= read -r file; do
      src="$main_root/$file"
      dest="$worktree_dir/$file"
      if [[ -f "$src" ]]; then
        mkdir -p "$(dirname "$dest")"
        cp -f "$src" "$dest"
        echo "copied: $file"
      else
        echo "warning: $file not found, skipping" >&2
      fi
    done <<< "$copy_files"
  fi
}

cmd_list() {
  local_usage() {
    cat <<EOF
usage: worktree list [-h]

List branches of worktrees for the current repo.

Outputs one branch name per line, suitable for piping to other
worktree subcommands (e.g. 'worktree remove').

Only worktrees located under \$REPO_DIR/worktree-<repo>-* are listed.

options:
  -h, --help    show this help message and exit
EOF
  }

  for arg in "$@"; do
    case $arg in
      -h|--help) local_usage; return 0 ;;
      *) local_usage >&2; return 1 ;;
    esac
  done

  # Validate REPO_DIR is set
  if [[ -z "${REPO_DIR:-}" ]]; then
    echo "error: REPO_DIR environment variable is not set" >&2
    return 1
  fi

  # Validate we're inside a git repo
  git rev-parse --show-toplevel >/dev/null 2>&1 || {
    echo "error: not inside a git repository" >&2
    return 1
  }

  main_root=$(main_worktree_root)
  repo_name=$(basename "$main_root")
  prefix="$REPO_DIR/worktree-${repo_name}-"

  # Walk porcelain output, emitting branch names for matching worktrees
  current_path=
  while IFS= read -r line; do
    case $line in
      "worktree "*) current_path=${line#worktree } ;;
      "branch "*)
        if [[ "$current_path" == "$prefix"* ]]; then
          # strip refs/heads/ prefix
          echo "${line#branch refs/heads/}"
        fi
        ;;
      "")
        current_path=
        ;;
    esac
  done < <(git worktree list --porcelain)
}

cmd_remove() {
  local_usage() {
    cat <<EOF
usage: worktree remove [-f] [-h] <branch>

Remove a git worktree by branch name.

arguments:
  branch        name of the branch whose worktree to remove

options:
  -f, --force   force-remove the worktree even if it has uncommitted changes
  -h, --help    show this help message and exit

the worktree is expected at \$REPO_DIR/worktree-<repo>-<branch>.
EOF
  }

  force=false

  # Pre-process --force and --help long flags
  args=()
  for arg in "$@"; do
    case $arg in
      --force) args+=("-f") ;;
      -h|--help) local_usage; return 0 ;;
      *) args+=("$arg") ;;
    esac
  done
  set -- "${args[@]+"${args[@]}"}"

  while getopts "fh" opt; do
    case $opt in
      f) force=true ;;
      h) local_usage; return 0 ;;
      *) local_usage >&2; return 1 ;;
    esac
  done
  shift $((OPTIND - 1))

  # Validate REPO_DIR is set
  if [[ -z "${REPO_DIR:-}" ]]; then
    echo "error: REPO_DIR environment variable is not set" >&2
    return 1
  fi

  # Require exactly one positional argument: <branch>
  if [[ $# -ne 1 ]]; then
    local_usage >&2
    return 1
  fi

  branch=$1

  # Validate we're inside a git repo
  git rev-parse --show-toplevel >/dev/null 2>&1 || {
    echo "error: not inside a git repository" >&2
    return 1
  }

  worktree_dir=$(worktree_path_for "$branch")

  if [[ "$force" == true ]]; then
    git worktree remove --force "$worktree_dir"
  else
    git worktree remove "$worktree_dir"
  fi

  echo "worktree removed: $worktree_dir"
}

# Main dispatch
if [[ $# -lt 1 ]]; then
  usage >&2
  exit 1
fi

case $1 in
  -h|--help) usage; exit 0 ;;
  add)    shift; cmd_add "$@" ;;
  list)   shift; cmd_list "$@" ;;
  remove) shift; cmd_remove "$@" ;;
  config) shift; cmd_config "$@" ;;
  *)
    echo "error: unknown command '$1'" >&2
    usage >&2
    exit 1
    ;;
esac
