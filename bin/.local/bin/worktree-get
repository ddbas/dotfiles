#!/usr/bin/env bash

# Prompt for a branch name, run `bs get -b <branch>`, parse the output,
# and attach to a new (or existing) tmux session in the resulting worktree.

# Ask the user for the branch name
echo -n "Branch Name: "
read -r branch_name

if [[ -z $branch_name ]]; then
  exit 1
fi

# Run bs get and capture output (strip ANSI / emoji colour codes just in case)
bs_output=$(bs get -b "$branch_name" 2>&1)

# If the branch already exists, offer to force-reset it with -B
if echo "$bs_output" | grep -q "a branch named '.*' already exists"; then
  echo -n "⚠️  Branch '${branch_name}' already exists. Proceed anyway? [y/N] "
  read -r confirm
  if [[ ! $confirm =~ ^[Yy]$ ]]; then
    echo "Aborted."
    exit 1
  fi
  bs_output=$(bs get -B "$branch_name" 2>&1)
fi

echo "$bs_output"

# Extract the worktree path – the token that starts with / after the tree emoji
# Example line: 🌳 /Users/davidbastien/.bonsai/repo-name/84cd7c88  (branch-name)
# Anchored to the emoji line's 2nd field so slashes in the branch name (e.g.
# "fix/circular-dependencies") aren't mistaken for another path.
worktree_path=$(echo "$bs_output" | awk '/🌳/{print $2; exit}')

if [[ -z $worktree_path ]]; then
  echo "Could not determine worktree path from bs output."
  exit 1
fi

# Derive repo-name (second-to-last path component) and branch name from path/output
repo_name=$(basename "$(dirname "$worktree_path")")
branch_display=$(echo "$bs_output" | grep -oP '(?<=\()([^)]+)(?=\))')
[[ -z $branch_display ]] && branch_display=$branch_name

session_name="🌳 ${repo_name} (${branch_display})"

# Create or attach to a tmux session for this worktree
if ! tmux has-session -t="$session_name" 2>/dev/null; then
  tmux new-session -ds "$session_name" -c "$worktree_path"
fi

tmux switch-client -t "$session_name"
