#!/usr/bin/env bash
#
# Print the GitHub URL for viewing an openspec change proposal in the browser.
# Usage: openspec-proposal-url <change-id>

set -euo pipefail

change_id=${1:?"Usage: openspec-proposal-url <change-id>"}

if ! openspec show "$change_id" --type change --json >/dev/null 2>&1; then
  echo "No openspec change named '${change_id}'" >&2
  exit 1
fi

remote_url=$(git remote get-url origin)
remote_url=${remote_url%.git}

if [[ $remote_url =~ ^git@([^:]+):(.+)$ ]]; then
  host=${BASH_REMATCH[1]}
  path=${BASH_REMATCH[2]}
elif [[ $remote_url =~ ^https?://([^/]+)/(.+)$ ]]; then
  host=${BASH_REMATCH[1]}
  path=${BASH_REMATCH[2]}
else
  echo "Could not parse git remote URL: $remote_url" >&2
  exit 1
fi

org=$(dirname "$path")
repo=$(basename "$path")
branch=$(git branch --show-current)

echo "https://${host}/${org}/${repo}/blob/${branch}/openspec/changes/${change_id}/"
