{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0"
  },
  "permissions": {
    "allow": [
      "Bash(bd *)",
      "Bash(brew *)",
      "Bash(cat *)",
      "Bash(cut *)",
      "Bash(env)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(openspec list *)",
      "Bash(openspec show *)",
      "Bash(openspec status *)",
      "Bash(printenv *)",
      "Bash(pwd)",
      "Bash(rg *)",
      "Bash(stat *)",
      "Bash(stow *)",
      "Bash(tail *)",
      "Bash(tree *)",
      "Bash(type *)",
      "Bash(uname *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(whoami)",
      "Bash(* --version)",
      "Bash(* --help *)",
      "Bash(rtk diff *)",
      "Bash(rtk env)",
      "Bash(rtk find *)",
      "Bash(rtk gh *)",
      "Bash(rtk git *)",
      "Bash(rtk grep *)",
      "Bash(rtk json *)",
      "Bash(rtk ls *)",
      "Bash(rtk npm *)",
      "Bash(rtk npx *)",
      "Bash(rtk read *)",
      "Bash(rtk rg *)",
      "Bash(rtk tree *)",
      "Bash(rtk wc *)",
      "mcp__codegraph__codegraph_explore",
      "mcp__codegraph__codegraph_search",
      "mcp__codegraph__codegraph_node",
      "mcp__codegraph__codegraph_callers",
      "mcp__codegraph__codegraph_callees",
      "mcp__codegraph__codegraph_impact",
      "mcp__codegraph__codegraph_files",
      "mcp__codegraph__codegraph_status",
      "mcp__git__get_commit",
      "mcp__git__get_file_contents",
      "mcp__git__get_label",
      "mcp__git__get_latest_release",
      "mcp__git__get_me",
      "mcp__git__get_release_by_tag",
      "mcp__git__get_tag",
      "mcp__git__get_team_members",
      "mcp__git__get_teams",
      "mcp__git__issue_read",
      "mcp__git__list_branches",
      "mcp__git__list_commits",
      "mcp__git__list_issue_types",
      "mcp__git__list_issues",
      "mcp__git__list_pull_requests",
      "mcp__git__list_releases",
      "mcp__git__list_tags",
      "mcp__git__pull_request_read",
      "mcp__git__search_code",
      "mcp__git__search_issues",
      "mcp__git__search_pull_requests",
      "mcp__git__search_repositories",
      "mcp__git__search_users",
      "mcp__jira__jira_get_issue",
      "mcp__wiki__getConfluencePage",
      "mcp__wiki__searchAtlassian"
    ]
  },
  "model": "sonnet[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt|permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime --stealth"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime --stealth"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "figma@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "theme": "dark-ansi",
  "skipAutoPermissionPrompt": true
}
